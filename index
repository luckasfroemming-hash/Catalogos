<!DOCTYPE html>

<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Catálogo</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600&display=swap');

:root {
–bg: #0c0c0c;
–card: #141414;
–border: #242424;
–accent: #e2ff5d;
–text: #efefef;
–muted: #606060;
–hover: #1c1c1c;
}

- { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
  font-family: ‘Inter’, sans-serif;
  background: var(–bg);
  color: var(–text);
  display: flex;
  min-height: 100vh;
  }

/* ─── SIDEBAR ──────────────────────────────────────────── */
aside {
width: 255px;
min-width: 255px;
background: var(–card);
border-right: 1px solid var(–border);
height: 100vh;
position: sticky;
top: 0;
overflow-y: auto;
display: flex;
flex-direction: column;
scrollbar-width: thin;
scrollbar-color: var(–border) transparent;
}
aside::-webkit-scrollbar { width: 3px; }
aside::-webkit-scrollbar-thumb { background: var(–border); border-radius: 2px; }

.sidebar-logo {
padding: 22px 18px 16px;
border-bottom: 1px solid var(–border);
}
.sidebar-logo h1 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 26px;
letter-spacing: 4px;
color: var(–accent);
line-height: 1;
}
.sidebar-logo p {
font-size: 10px;
color: var(–muted);
letter-spacing: 2px;
text-transform: uppercase;
margin-top: 4px;
}

.sidebar-search {
padding: 10px 12px;
border-bottom: 1px solid var(–border);
}
.sidebar-search input {
width: 100%;
background: #1a1a1a;
border: 1px solid var(–border);
border-radius: 6px;
padding: 8px 10px;
color: var(–text);
font-size: 12px;
outline: none;
transition: border-color .2s;
font-family: inherit;
}
.sidebar-search input:focus { border-color: var(–accent); }
.sidebar-search input::placeholder { color: var(–muted); }

.sidebar-nav { flex: 1; padding: 6px 0 20px; }

.nav-btn {
display: flex;
align-items: center;
gap: 9px;
width: 100%;
padding: 9px 16px;
background: none;
border: none;
border-bottom: 1px solid #1a1a1a;
color: var(–muted);
font-family: inherit;
font-size: 11.5px;
cursor: pointer;
text-align: left;
transition: background .12s, color .12s;
}
.nav-btn.live { color: var(–text); }
.nav-btn:hover, .nav-btn.active { background: var(–hover); color: var(–accent); }
.nav-btn .badge {
margin-left: auto;
background: var(–accent);
color: #000;
font-size: 9px;
font-weight: 700;
padding: 2px 6px;
border-radius: 4px;
flex-shrink: 0;
}

/* ─── MAIN ──────────────────────────────────────────────── */
main { flex: 1; display: flex; flex-direction: column; }

.topbar {
background: var(–card);
border-bottom: 1px solid var(–border);
padding: 15px 28px;
display: flex;
align-items: center;
justify-content: space-between;
position: sticky;
top: 0;
z-index: 10;
}
.topbar h2 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 20px;
letter-spacing: 2px;
}
.topbar span { font-size: 11px; color: var(–muted); letter-spacing: 1px; }

.page-content { flex: 1; padding: 28px; }

/* hero */
.hero {
background: linear-gradient(135deg, #141414 0%, #1a1a1a 55%, #111 100%);
border: 1px solid var(–border);
border-radius: 12px;
padding: 48px 44px;
margin-bottom: 32px;
position: relative;
overflow: hidden;
}
.hero::before {
content: ‘’;
position: absolute;
top: -30%; right: -5%;
width: 320px; height: 320px;
background: radial-gradient(circle, rgba(226,255,93,.08) 0%, transparent 70%);
pointer-events: none;
}
.hero h2 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 54px;
letter-spacing: 5px;
line-height: 1;
margin-bottom: 12px;
}
.hero h2 span { color: var(–accent); }
.hero p { font-size: 13px; color: var(–muted); line-height: 1.8; max-width: 400px; }
.hero-nums { display: flex; gap: 32px; margin-top: 24px; }
.hero-nums .n { font-family: ‘Bebas Neue’, sans-serif; font-size: 34px; color: var(–accent); line-height: 1; }
.hero-nums .l { font-size: 10px; color: var(–muted); text-transform: uppercase; letter-spacing: 2px; margin-top: 3px; }

/* section label */
.sec { font-family: ‘Bebas Neue’, sans-serif; font-size: 12px; letter-spacing: 3px; color: var(–muted); margin-bottom: 14px; padding-bottom: 8px; border-bottom: 1px solid var(–border); }

/* category cards on homepage */
.cat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(145px, 1fr)); gap: 10px; }
.cat-card {
background: var(–card);
border: 1px solid var(–border);
border-radius: 10px;
padding: 16px 14px;
cursor: pointer;
text-align: center;
transition: background .15s, border-color .15s, transform .15s;
}
.cat-card.live { border-color: #2a2a2a; }
.cat-card:hover { background: var(–hover); border-color: #383838; transform: translateY(-2px); }
.cat-card .icon { font-size: 26px; margin-bottom: 8px; }
.cat-card .name { font-size: 11.5px; font-weight: 600; line-height: 1.3; }
.cat-card .info { font-size: 10px; color: var(–muted); margin-top: 4px; }
.cat-card .pill {
display: inline-block;
margin-top: 6px;
background: rgba(226,255,93,.12);
color: var(–accent);
border: 1px solid rgba(226,255,93,.25);
font-size: 9px;
font-weight: 700;
letter-spacing: .8px;
padding: 2px 7px;
border-radius: 4px;
}

/* product grid */
.prod-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(192px, 1fr)); gap: 14px; }
.prod-card {
background: var(–card);
border: 1px solid var(–border);
border-radius: 10px;
overflow: hidden;
cursor: pointer;
transition: transform .15s, border-color .15s, box-shadow .15s;
}
.prod-card:hover { transform: translateY(-3px); border-color: #3a3a3a; box-shadow: 0 10px 32px rgba(0,0,0,.6); }
.prod-card img {
width: 100%;
aspect-ratio: 1 / 1;
object-fit: cover;
display: block;
background: #1a1a1a;
}
.prod-card .prod-info { padding: 10px 12px 13px; }
.prod-card .prod-title {
font-size: 12px;
font-weight: 500;
line-height: 1.45;
overflow: hidden;
display: -webkit-box;
-webkit-line-clamp: 2;
-webkit-box-orient: vertical;
}
.prod-card .prod-cat { font-size: 10px; color: var(–muted); margin-top: 3px; }
.prod-card .prod-photos { font-size: 10px; color: var(–accent); font-weight: 600; margin-top: 4px; }

/* empty */
.empty { text-align: center; padding: 64px 20px; color: var(–muted); }
.empty .e-icon { font-size: 44px; margin-bottom: 14px; }
.empty p { font-size: 13px; line-height: 1.8; }

/* ─── LIGHTBOX ──────────────────────────────────────────── */
#lightbox {
display: none;
position: fixed;
inset: 0;
background: rgba(0,0,0,.97);
z-index: 9999;
flex-direction: column;
align-items: center;
justify-content: center;
}
#lightbox.open { display: flex; }

#lb-close {
position: absolute;
top: 16px; right: 20px;
background: rgba(255,255,255,.1);
border: none; color: #fff;
font-size: 18px;
width: 38px; height: 38px;
border-radius: 50%;
cursor: pointer;
display: flex; align-items: center; justify-content: center;
transition: background .15s;
}
#lb-close:hover { background: rgba(255,255,255,.2); }

#lb-counter {
position: absolute;
top: 20px; left: 20px;
font-family: ‘Bebas Neue’, sans-serif;
font-size: 17px;
letter-spacing: 2px;
color: var(–accent);
}

.lb-wrap {
display: flex;
align-items: center;
gap: 8px;
max-width: 92vw;
max-height: 78vh;
}
#lb-img {
max-width: calc(92vw - 100px);
max-height: 78vh;
object-fit: contain;
border-radius: 8px;
display: block;
transition: opacity .18s;
}
.lb-arrow {
background: rgba(255,255,255,.08);
border: none; color: #fff;
font-size: 24px;
width: 44px; height: 44px;
border-radius: 50%;
cursor: pointer;
display: flex; align-items: center; justify-content: center;
flex-shrink: 0;
transition: background .15s;
}
.lb-arrow:hover { background: rgba(255,255,255,.2); }
.lb-arrow:disabled { opacity: .15; cursor: default; }

#lb-title {
position: absolute;
bottom: 56px; left: 50%; transform: translateX(-50%);
color: #bbb; font-size: 11px; letter-spacing: .8px;
background: rgba(0,0,0,.7);
padding: 5px 16px; border-radius: 20px;
white-space: nowrap; max-width: 88vw;
overflow: hidden; text-overflow: ellipsis;
}

#lb-thumbs {
position: absolute;
bottom: 10px; left: 50%; transform: translateX(-50%);
display: flex; gap: 5px;
max-width: 90vw; overflow-x: auto;
padding: 3px; scrollbar-width: none;
}
#lb-thumbs::-webkit-scrollbar { display: none; }
#lb-thumbs img {
width: 44px; height: 44px;
object-fit: cover; border-radius: 4px;
cursor: pointer; opacity: .4;
transition: opacity .15s;
flex-shrink: 0;
border: 1px solid transparent;
}
#lb-thumbs img.on { opacity: 1; border-color: var(–accent); }

/* mobile */
#mob-btn {
display: none;
position: fixed; bottom: 18px; right: 18px;
width: 48px; height: 48px;
background: var(–accent); color: #000;
border: none; border-radius: 50%;
font-size: 20px; cursor: pointer;
z-index: 999;
box-shadow: 0 4px 20px rgba(226,255,93,.3);
align-items: center; justify-content: center;
}
@media (max-width: 768px) {
aside { position: fixed; left: -255px; top: 0; z-index: 50; transition: left .28s; }
aside.open { left: 0; }
#mob-btn { display: flex; }
.page-content { padding: 16px; }
.hero { padding: 28px 20px; }
.hero h2 { font-size: 38px; }
.topbar { padding: 12px 16px; }
#lb-img { max-width: calc(92vw - 72px); max-height: 72vh; }
}

footer { padding: 18px 28px; border-top: 1px solid var(–border); display: flex; justify-content: space-between; }
footer p { font-size: 10px; color: var(–muted); letter-spacing: 1px; }
</style>

</head>
