  { name:"Kids' Shoes",        icon:'👶', live:false },
  { name:'Clothing',           icon:'👕', live:false }
];

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// SIDEBAR
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
var nav = document.getElementById('sidebar-nav');

var homeBtn = document.createElement('button');
homeBtn.className = 'nav-btn live active';
homeBtn.dataset.search = 'inicio home';
homeBtn.innerHTML = '<span>🏠</span><span>Início</span>';
homeBtn.onclick = function() { setActive(homeBtn); renderHome(); };
nav.appendChild(homeBtn);

CATS.forEach(function(cat) {
  var btn = document.createElement('button');
  var count = PRODUCTS.filter(function(p){ return p.cat === cat.name; }).length;
  btn.className = 'nav-btn' + (cat.live ? ' live' : '');
  btn.dataset.search = cat.name.toLowerCase();
  btn.innerHTML = '<span>' + cat.icon + '</span><span>' + cat.name + '</span>'
    + (cat.live ? '<span class="badge">' + count + '</span>' : '');
  btn.onclick = function() { setActive(btn); renderCat(cat.name, cat.icon); };
  nav.appendChild(btn);
});

function setActive(el) {
  document.querySelectorAll('.nav-btn').forEach(function(b){ b.classList.remove('active'); });
  el.classList.add('active');
}

document.getElementById('search-inp').addEventListener('input', function() {
  var q = this.value.toLowerCase();
  document.querySelectorAll('.nav-btn').forEach(function(btn) {
    btn.style.display = (!q || btn.dataset.search.includes(q)) ? '' : 'none';
  });
});

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// HOME
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function renderHome() {
  document.getElementById('page-title').textContent = 'CATÁLOGO';
  document.getElementById('page-sub').textContent = '';

  var html = '<div class="hero">'
    + '<h2>PRODUTOS<br><span>PREMIUM</span></h2>'
    + '<p>Navegue pelas categorias no menu lateral. Clique num produto para abrir as fotos em tela cheia.</p>'
    + '<div class="hero-nums">'
    + '<div><div class="n">' + PRODUCTS.length + '</div><div class="l">Produtos</div></div>'
    + '<div><div class="n">3</div><div class="l">Categorias</div></div>'
    + '<div><div class="n">40+</div><div class="l">Coleções</div></div>'
    + '</div></div>'
    + '<p class="sec">CATEGORIAS</p>'
    + '<div class="cat-grid" id="home-cats"></div>';
  document.getElementById('page-content').innerHTML = html;

  var grid = document.getElementById('home-cats');
  CATS.forEach(function(cat) {
    var count = PRODUCTS.filter(function(p){ return p.cat === cat.name; }).length;
    var card = document.createElement('div');
    card.className = 'cat-card' + (cat.live ? ' live' : '');
    card.innerHTML = '<div class="icon">' + cat.icon + '</div>'
      + '<div class="name">' + cat.name + '</div>'
      + '<div class="info">' + (cat.live ? count + ' modelos' : 'em breve') + '</div>'
      + (cat.live ? '<div class="pill">DISPONÍVEL</div>' : '');
    if (cat.live) {
      card.onclick = (function(n, ic){ return function(){ renderCat(n, ic); }; })(cat.name, cat.icon);
    }
    grid.appendChild(card);
  });
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// CATEGORY PAGE
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
function renderCat(name, icon) {
  var prods = PRODUCTS.filter(function(p){ return p.cat === name; });
  document.getElementById('page-title').textContent = name.toUpperCase();
  document.getElementById('page-sub').textContent = prods.length + ' modelos';

  if (!prods.length) {
    document.getElementById('page-content').innerHTML =
      '<div class="empty"><div class="e-icon">' + (icon||'📦') + '</div>'
      + '<p>' + name + '<br>Em breve.</p></div>';
    return;
  }

  document.getElementById('page-content').innerHTML = '<div class="prod-grid" id="pg"></div>';
  var grid = document.getElementById('pg');

  prods.forEach(function(prod) {
    var card = document.createElement('div');
    card.className = 'prod-card';
    var photoLabel = prod.photos.length > 1 ? '<div class="prod-photos">📷 ' + prod.photos.length + ' fotos</div>' : '';
    card.innerHTML =
      '<img src="' + imgUrl(prod.cover) + '" alt="' + prod.title + '" loading="lazy" onerror="this.style.background=\'#222\'">'
      + '<div class="prod-info">'
      + '<div class="prod-title">' + prod.title + '</div>'
      + '<div class="prod-cat">' + prod.cat + '</div>'
      + photoLabel
      + '</div>';
    card.onclick = (function(p){ return function(){ openLightbox(p); }; })(prod);
    grid.appendChild(card);
  });
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// LIGHTBOX
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
var LB = { photos: [], idx: 0, title: '' };

function openLightbox(prod) {
  LB.photos = prod.photos;
  LB.idx = 0;
  LB.title = prod.title;
  document.getElementById('lightbox').classList.add('open');
  document.body.style.overflow = 'hidden';
  drawLightbox();
}

function drawLightbox() {
  var img = document.getElementById('lb-img');
  img.style.opacity = '0.3';
  img.src = imgUrl(LB.photos[LB.idx]);
  img.onload = function() { img.style.opacity = '1'; };
  img.onerror = function() { img.src = imgUrl(LB.photos[LB.idx], 'small'); img.style.opacity = '1'; };

  document.getElementById('lb-counter').textContent = (LB.idx + 1) + ' / ' + LB.photos.length;
  document.getElementById('lb-title').textContent = LB.title;
  document.getElementById('lb-prev').disabled = LB.idx === 0;
  document.getElementById('lb-next').disabled = LB.idx === LB.photos.length - 1;

  var strip = document.getElementById('lb-thumbs');
  if (LB.photos.length > 1) {
    strip.innerHTML = LB.photos.map(function(h, i) {
      return '<img src="' + imgUrl(h, 'small') + '" class="' + (i === LB.idx ? 'on' : '') + '" onclick="jumpLB(' + i + ')" onerror="this.style.display=\'none\'">';
    }).join('');
    strip.style.display = 'flex';
  } else {
    strip.style.display = 'none';
  }
}

function jumpLB(i) { LB.idx = i; drawLightbox(); }

function closeLightbox() {
  document.getElementById('lightbox').classList.remove('open');
  document.body.style.overflow = '';
}

document.getElementById('lb-close').onclick = closeLightbox;
document.getElementById('lb-prev').onclick = function() { if (LB.idx > 0) { LB.idx--; drawLightbox(); } };
document.getElementById('lb-next').onclick = function() { if (LB.idx < LB.photos.length - 1) { LB.idx++; drawLightbox(); } };
document.getElementById('lightbox').addEventListener('click', function(e) {
  if (e.target === this) closeLightbox();
});
document.addEventListener('keydown', function(e) {
  if (!document.getElementById('lightbox').classList.contains('open')) return;
  if (e.key === 'Escape') closeLightbox();
  if (e.key === 'ArrowLeft'  && LB.idx > 0)                    { LB.idx--; drawLightbox(); }
  if (e.key === 'ArrowRight' && LB.idx < LB.photos.length - 1) { LB.idx++; drawLightbox(); }
});
var tX = 0;
document.getElementById('lightbox').addEventListener('touchstart', function(e) { tX = e.touches[0].clientX; }, { passive: true });
document.getElementById('lightbox').addEventListener('touchend', function(e) {
  var dx = e.changedTouches[0].clientX - tX;
  if (Math.abs(dx) > 50) {
    if (dx < 0 && LB.idx < LB.photos.length - 1) { LB.idx++; drawLightbox(); }
    if (dx > 0 && LB.idx > 0)                     { LB.idx--; drawLightbox(); }
  }
}, { passive: true });

// mobile menu
document.getElementById('mob-btn').onclick = function() {
  document.getElementById('sidebar').classList.toggle('open');
};
document.querySelector('main').addEventListener('click', function() {
  document.getElementById('sidebar').classList.remove('open');
});

